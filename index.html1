<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Currency Converter</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
  <main class="converter-page">
    <section class="converter">
      <div class="heading">
        <p>Web Development Project</p>
        <h1>Currency Converter</h1>
      </div>

      <form id="converterForm" class="converter-form">
        <label for="amount">Amount</label>
        <input id="amount" type="number" min="0" step="0.01" value="1" required>

        <div class="currency-row">
          <div>
            <label for="fromCurrency">From</label>
            <select id="fromCurrency"></select>
          </div>

          <button class="swap-button" id="swapButton" type="button" aria-label="Swap currencies">&harr;</button>

          <div>
            <label for="toCurrency">To</label>
            <select id="toCurrency"></select>
          </div>
        </div>

        <button class="convert-button" type="submit">Convert</button>
      </form>

      <section class="result-box" aria-live="polite">
        <p id="resultLabel">Converted Amount</p>
        <strong id="resultValue">&#8377;83.20</strong>
        <span id="rateInfo">1 USD = 83.20 INR</span>
      </section>
    </section>
  </main>

  <script src="script.js"></script>
</body>
</html>
